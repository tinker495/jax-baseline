# jax-baselines runtime configuration.
#
# Copy to `.env` (which is gitignored) and edit. The console runners
# (qnet / dpg / pg / impala / apex-qnet / apex-dpg / exp) load this file
# automatically. Precedence: explicit CLI flag > real shell env var > .env > default.

# --- Logging backend ---------------------------------------------------------
# Which logger to use: tensorboard (default) | wandb | aim   (CLI: --logger)
JAXBL_LOGGER=tensorboard

# Root directory for logs / checkpoints / videos (a per-family subdir is appended).
# CLI: --logdir
JAXBL_LOG_DIR=runs

# --- Weights & Biases (JAXBL_LOGGER=wandb) -----------------------------------
# The W&B project is the experiment name (--experiment_name), not a separate var.
# The API key is read by the wandb SDK itself; keep it here since .env is gitignored.
# WANDB_API_KEY=
# WANDB_ENTITY=your-team-or-user   # CLI: --wandb_entity
# WANDB_MODE=online                # online | offline | disabled   CLI: --wandb_mode

# --- Aim (JAXBL_LOGGER=aim) --------------------------------------------------
# AIM_REPO=./.aim                  # CLI: --aim_repo
